# Aone — environment variables
# Copy to `.env` and fill in the values. `.env` is in .gitignore (never committed).

# ─── REQUIRED (free-tier v0 stack) ───

# Groq — generation + classification (https://console.groq.com)
GROQ_API_KEY=

# Langfuse Cloud — tracing (https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── MODELS (free defaults; override to use paid providers) ───

AONE_MODEL_GENERATION=groq/llama-3.3-70b-versatile
AONE_MODEL_CLASSIFICATION=groq/llama-3.1-8b-instant

AONE_EMBEDDING_PROVIDER=local
AONE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── OTHER ───

AONE_SYNC_LIMIT=500

# ─── OPTIONAL (only if swapping to paid models) ───

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
